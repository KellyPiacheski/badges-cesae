# Base de dados (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host-unpooled/dbname?sslmode=require

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# Servidor
PORT=3001

# URL pública do servidor (usado para construir URLs absolutas dos badges/certificados)
# Em produção: URL do Railway ou outro serviço de deploy
SERVER_URL=https://badges-cesae-production.up.railway.app

# Email (Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
